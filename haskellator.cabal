source-repository head
  type: git
  location: https://github.com/JoyOfHardware/haskellator

library
  exposed-modules:
      RTLIL
      RTLIL.Flags
      RTLIL.Parse
      RTLIL.Syntax
  other-modules:
      Paths_haskellator
  hs-source-dirs:
      src
  default-extensions:
      LambdaCase
      TupleSections
      ViewPatterns
  ghc-options: -Wall -O2 -Wcompat -Widentities -Wincomplete-record-updates -Wincomplete-uni-patterns -Wmissing-export-lists -Wmissing-home-modules -Wpartial-fields -Wredundant-constraints
  build-depends:
      attoparsec
    , base >=4.7 && <5
    , filepath
    , prettyprinter
    , text
  default-language: Haskell2010

executable rtlil-parse
  main-is: Main.hs
  other-modules:
      Paths_haskellator
  hs-source-dirs:
      app
  default-extensions:
      LambdaCase
      TupleSections
      ViewPatterns
  ghc-options: -Wall -O2 -Wcompat -Widentities -Wincomplete-record-updates -Wincomplete-uni-patterns -Wmissing-export-lists -Wmissing-home-modules -Wpartial-fields -Wredundant-constraints -threaded -rtsopts -with-rtsopts=-N
  build-depends:
      attoparsec
    , base >=4.7 && <5
    , filepath
    , haskellator
    , prettyprinter
    , text
  default-language: Haskell2010

test-suite haskellator-test
  type: exitcode-stdio-1.0
  main-is: Spec.hs
  other-modules:
      Paths_haskellator
  hs-source-dirs:
      test
  default-extensions:
      LambdaCase
      TupleSections
      ViewPatterns
  ghc-options: -Wall -O2 -Wcompat -Widentities -Wincomplete-record-updates -Wincomplete-uni-patterns -Wmissing-export-lists -Wmissing-home-modules -Wpartial-fields -Wredundant-constraints -threaded -rtsopts -with-rtsopts=-N
  build-depends:
      attoparsec
    , base >=4.7 && <5
    , directory
    , filepath
    , haskellator
    , prettyprinter
    , tasty
    , tasty-golden
    , text
  default-language: Haskell2010
